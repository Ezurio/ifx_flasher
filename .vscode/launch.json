{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug ifx_flasher",
            "type": "debugpy",
            "request": "launch",
            "program": "ifx_flasher_cli.py",
            "console": "integratedTerminal",
            //"args": "${command:pickArgs}"
            "args": [
                "-b",
                "${input:board}",
                "-ce",
                "-f",
                "${input:firmware}"
            ],
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "board",
            "type": "pickString",
            "description": "Select board",
            "options": [
                "if820",
                "if91x",
                "if310",
            ],
            "default": "if820"
        },
        {
            "id": "firmware",
            "type": "promptString",
            "description": "firmware path",
            "default": ""
        }
    ]
}
